{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(mise:*)",
      "Bash(python:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(node:*)",
      "Bash(bun:*)",
      "Bash(npx:*)",
      "Bash(biome:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/git-workflow/scripts/validate_message.py"
          }
        ]
      }
    ]
  }
}
