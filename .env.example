# MESO Negotiation Backend — Environment Configuration
# Copy this file to .env and adjust values for your environment.
# All values shown are the application defaults.

# CORS: allowed origins for the React frontend (space or comma-separated)
CORS_ORIGINS=["http://localhost:5173"]

# Enable debug mode (verbose errors)
DEBUG=false

# FastAPI application title (shown in /docs)
APP_TITLE=MESO Negotiation Engine

# Seed a demo negotiation on startup
SEED_DEMO=true

# Boulware concession curve: shape parameter (higher = more aggressive concession)
DEFAULT_BETA=2.0

# Concession curve: starting utility (operator's ideal, round 1)
OPENING_UTILITY=1.0

# Concession curve: minimum acceptable utility (floor)
WALKAWAY_UTILITY=0.35
